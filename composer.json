{
    "name": "ashrafic/filament-white-label",
    "description": "Total panel rebranding. For you and every tenant. No code.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ashrafic Labs",
            "email": "hello@ashraficlabs.com",
            "homepage": "https://ashraficlabs.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "FilamentWhiteLabel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FilamentWhiteLabel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilamentWhiteLabel\\Providers\\FilamentWhiteLabelServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "lint:fix": "pint --fix"
    }
}